  "Converts a ROS message object to a list"
  (cl:list 'pwm_values
    (cl:cons ':header (header msg))
    (cl:cons ':Force (Force msg))
    (cl:cons ':Moment (Moment msg))
    (cl:cons ':Actuation (Actuation msg))
    (cl:cons ':PWM (PWM msg))
    (cl:cons ':rpm (rpm msg))
    (cl:cons ':Att_P_gains (Att_P_gains msg))
    (cl:cons ':Att_I_gains (Att_I_gains msg))
    (cl:cons ':Att_D_gains (Att_D_gains msg))
    (cl:cons ':Current_rpy (Current_rpy msg))
    (cl:cons ':Desired_rpy (Desired_rpy msg))
    (cl:cons ':Desired_position (Desired_position msg))
    (cl:cons ':Desired_velocity (Desired_velocity msg))
    (cl:cons ':Desired_omega (Desired_omega msg))
    (cl:cons ':Error_rpy (Error_rpy msg))
    (cl:cons ':err_int (err_int msg))
    (cl:cons ':Time_Step (Time_Step msg))
    (cl:cons ':Quat_error (Quat_error msg))
))
