#include <iostream>
#include "ros/ros.h"
#include <vector>
#include <opencv2/opencv.hpp>
#include <eigen3/Eigen/Geometry>
#include <cmath>




using namespace std;
#define PI 3.14159

struct traj_struct {
    Eigen::Vector3d xd;
    Eigen::Vector3d vd;
    Eigen::Matrix3d Rd;
    Eigen::Vector3d ori;
    Eigen::Vector3d Od;

};


double deg2rad(double deg){
    return deg*(PI/180);
}

double rad2deg(double rad){
    return rad*(180/PI);
}
///get_norm is not needed as you can directly use the Rodrigues formula from openCV
double get_norm(vector<double> num){
    return sqrt(num[0]*num[0] + num[1]*num[1] + num[2]*num[2]);
}

void expr(vector<double> omega, Eigen::Matrix3d& Rd, traj_struct&  tempp){
    double n = get_norm(omega);
    cv::Mat cvRd(3, 3, CV_32FC1);

    ///if n=0 then Rd = Identity matrix
    if(n==0) {
        for (int i = 0; i < 3; i++) {
            tempp.ori[i] = 0;
            for (int j = 0; j < 3; j++) {
                if (i == j)
                    Rd(i,j) = 1;
                else
                    Rd(i,j) = 0;

            }
        }
    }
    /// n!=0 then set it using Rodrigues formula
    else{
        cv::Rodrigues(omega, cvRd);
        for(int i=0; i<3; i++){
            tempp.ori[i] = omega[i];
            for(int j=0; j<3; j++) {
                Rd(i,j) = cvRd.ptr<float>(i)[j];
                tempp.Rd(i,j) = Rd(i,j);
            }
        }

    }

}

//need to declare a default TRAJ1 as in the V-REP-Roque code
void gen_from_traj(double waypoints[9][7], vector<double>& xd, vector<double>& vd, Eigen::Matrix3d Rd, vector<double>& Od, vector<traj_struct>& out){

    ///Need to find better ways to find the number of rows!!!!!!!!!!!!!!!!!!!!1----- THIS IS WRONG
    //int num_rows = sizeof(waypoints)/sizeof(waypoints[0]);
    //cout<<"num_rows: "<<num_rows<<endl;
    int num_rows =9;
    vector<double> pi(6), pf(6), xi(3), oi(3), xf(3), of(3), temp_oi(3);
    double tt, ti, tf;

    traj_struct res;



    double T = 0.01;

    ///So what we are doing here is for every waypoint, we divide it into many parts given by tt/T and for each one of them we generate xd, vd, Rd, Od and give it add it to the vector of struct.
    for(int i=0; i<num_rows -1; i++ ){
        ti = waypoints[i][0];
        tf = waypoints[i+1][0];
        tt= tf - ti;

        ///assigning values to the pose, position and orientation
        for(int j=0; j<6; j++){
            pi[j] = waypoints[i][j+1];
            pf[j] = waypoints[i+1][j+1];
        }

        for(int j=0; j<3; j++){
            xi[j] = pi[j];
            xf[j] = pf[j];
            oi[j] = pi[j+3];
            of[j] = pf[j+3];

        }

        ///Print all the values just to check
        ///
        ///
        ///Here is where all the action is: The time between next waypoint and the current waypoint  (say tt) is broken into tt/T segments, for each of which we calculate
        for(double t=0; t<tt; t=t+T){

            ///performing the algebraic operations on the vectors
            for(int k=0; k<3; k++){
                xd[k] = xi[k] + (xf[k] -xi[k])*t/tt;
                res.xd[k] = xd[k];
                vd[k] = (xf[k] - xi[k])/tt;
                res.vd[k] = vd[k];
                Od[k] = (of[k] - oi[k])/tt;
                res.Od[k] = Od[k];
                temp_oi[k] = oi[k] + (of[k] - oi[k])*t/tt;
            }

            expr(temp_oi, Rd, res);
            out.push_back(res);

        }
        //cout<<"So this went okay!"<<endl;

    }
}

